[
 {
  "zh": "윤하준",  
  "vi": "Doãn Cảnh Trạch",
  "pinyin": "Yoon Ha Joon",
  "story": "Ta Muội Muội Là Cái Thiên Tài",
  "country": "Hàn Quốc",
  "wiki": {
    "title": "Doãn Cảnh Trạch",
    "meta": "Nhân vật chính trong Ta Muội Muội Là Cái Thiên Tài",
    "year": "17 tuổi",
    "job": "Đang theo học tại Seolwon nghệ thuật cao trung, thực dùng âm nhạc khoa, soạn nhạc hệ",
    "work": "Tác phẩm tiêu biểu...",
    "content": "<p>Doãn Cảnh Trạch kiếp trước bởi vì chính mình cố chấp ca sĩ mộng tưởng mà dần dẫn xa cách chính mình mụ mụ và muội muội. Đến khi mụ mụ mất vì quá lao, muội muội bỏ dỡ chính mình mộng tưởng hắn mới ý thức được chính mình là cỡ nào bất kham một người. Trải qua một hồi trọng sinh, Doãn Cảnh Trạch trở về năm hắn vừa mới tốt nghiệp sơ trung, về tới khi mọi chuyện còn có thể cứu vãn, hắn quyết tâm đời này sẽ hiếu thuận mụ mụ, trợ giúp chính mình muội muội thực hiện mộng tưởng. Bắt đầu với việc từ bỏ chính hắn ca sĩ mộng tưởng xoay sang học làm soạn nhạc.</p>"
  }
},
